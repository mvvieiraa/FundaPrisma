

generator client {
  provider = "prisma-client"

}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//Comando: npx prisma db push - para criar a tabela no banco de dados
// Comando: npx prisma db pull - para atualizar o schema.prisma com as tabelas do banco de dados
model User {
  id Int @id @default(autoincrement())
  name String 
  email String @unique
}
